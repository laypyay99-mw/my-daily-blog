rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow public read access to posts and comments
    match /posts/{postId} {
      allow read: if true;

      // Only allow authenticated users to create, update, and delete posts.
      // This establishes your "admin rights".
      allow create, update, delete: if request.auth != null;

      match /comments/{commentId} {
        allow read: if true;
        // Allow anyone to create comments
        allow create: if true;
        // Only an admin should be able to delete comments
        allow delete: if request.auth != null;
      }
    }
  }
}
